_global_script_class_icons={

}

[application]

config/name="Yiffantes All Stars"
run/main_scene="res://Levels/DumbLevel.tscn"
config/icon="res://icon.png"

[autoload]

resolution="*res://Scripts/resolution.gd"
globalls="*res://Scripts/globalls.gd"

[display]

